# Seny server URL (no trailing slash)
SENY_URL=http://localhost:8000

# Your screen agent API key from Seny Settings → General → Screen Agent
SCREEN_AGENT_KEY=your_key_here

# How often to take a screenshot and evaluate (seconds). Default: 180 (3 minutes)
EVAL_INTERVAL=180

# How long without mouse/keyboard input before this machine is considered idle (seconds). Default: 60
IDLE_THRESHOLD=60

# Unique name for this machine (auto-detected if left blank)
MACHINE_ID=
