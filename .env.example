# =============================================================================
# Seny Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Only ANTHROPIC_API_KEY and SECRET_KEY are required to start.
# Everything else is optional — add integrations as you need them.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — App won't start without these
# -----------------------------------------------------------------------------

# Your Anthropic API key (get one at https://console.anthropic.com/api-keys)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Random secret for login security. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-random-secret-key

# -----------------------------------------------------------------------------
# RECOMMENDED — Important for production deployment
# -----------------------------------------------------------------------------

# Your app's public URL (Railway shows this in project settings)
# APP_URL=https://your-app.up.railway.app

# Allowed browser origins (set to your app URL for production)
# CORS_ORIGINS=https://your-app.up.railway.app

# PostgreSQL connection string (Railway sets this automatically when you add PostgreSQL)
# If not set, the app uses SQLite (data lost on container restart)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# -----------------------------------------------------------------------------
# OPTIONAL — Claude Model
# -----------------------------------------------------------------------------

# Override the default Claude model (default: claude-sonnet-4-5-20250929)
# CLAUDE_MODEL=claude-sonnet-4-5-20250929

# -----------------------------------------------------------------------------
# OPTIONAL — Google (Gmail, Calendar, Drive, Contacts)
# -----------------------------------------------------------------------------
# Required for Gmail, Google Calendar, Google Drive, and Contacts integrations.
# Set up OAuth credentials at https://console.cloud.google.com
# See docs/guides/GMAIL_SETUP.md for step-by-step instructions.

# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# OPTIONAL — Microsoft (Outlook, OneDrive)
# -----------------------------------------------------------------------------
# Required for Microsoft Outlook and OneDrive integrations.
# Set up at https://portal.azure.com → App registrations
# See docs/guides/MICROSOFT_SETUP.md for step-by-step instructions.

# MICROSOFT_CLIENT_ID=your-microsoft-client-id
# MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# -----------------------------------------------------------------------------
# OPTIONAL — Slack
# -----------------------------------------------------------------------------
# Required for Slack integration.
# Create a Slack App at https://api.slack.com/apps

# SLACK_CLIENT_ID=your-slack-client-id
# SLACK_CLIENT_SECRET=your-slack-client-secret
# SLACK_SIGNING_SECRET=your-slack-signing-secret

# -----------------------------------------------------------------------------
# OPTIONAL — Telegram
# -----------------------------------------------------------------------------
# For Telegram bot: create a bot via @BotFather on Telegram
# For Telegram client: get API credentials at https://my.telegram.org

# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_API_ID=your-telegram-api-id
# TELEGRAM_API_HASH=your-telegram-api-hash
# TELEGRAM_WEBHOOK_SECRET=a-random-string-for-webhook-verification

# -----------------------------------------------------------------------------
# OPTIONAL — Embeddings (Voyage AI)
# -----------------------------------------------------------------------------
# For semantic search across your data. Get an API key at https://www.voyageai.com

# VOYAGE_API_KEY=your-voyage-api-key
# CHROMA_PATH=/data/chroma

# -----------------------------------------------------------------------------
# OPTIONAL — Push Notifications
# -----------------------------------------------------------------------------
# For browser push notifications. Generate VAPID keys with:
#   npx web-push generate-vapid-keys

# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_EMAIL=mailto:your-email@example.com

# -----------------------------------------------------------------------------
# OPTIONAL — Fun
# -----------------------------------------------------------------------------

# GIPHY_API_KEY=your-giphy-api-key

# -----------------------------------------------------------------------------
# ADVANCED — Usually don't need to change these
# -----------------------------------------------------------------------------

# Server port (Railway sets this automatically)
# PORT=8000

# SQLite database path (only used if DATABASE_URL is not set)
# DATABASE_PATH=data/seny.db
